# Master encryption key for wallet storage (64 hex chars)
ENCRYPTION_KEY=your-64-char-hex-key-here

# RPC endpoints (optional — defaults to public RPCs)
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_BASE=https://mainnet.base.org
RPC_SCROLL=https://rpc.scroll.io
RPC_LINEA=https://rpc.linea.build
RPC_ZKSYNC=https://mainnet.era.zksync.io
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc

# Airdrop Center API (optional — for syncing activity)
AIRDROP_CENTER_URL=https://airdrop-center-production.up.railway.app
